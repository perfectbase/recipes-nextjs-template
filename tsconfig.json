{
  "compilerOptions": {
    // Target and Library Options
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],

    // JavaScript Support
    "allowJs": true,
    "checkJs": true,

    // Type Checking
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "verbatimModuleSyntax": true,

    // Module Resolution
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,

    // JSX
    "jsx": "preserve",

    // Build Options
    "noEmit": true,
    "incremental": true,

    // Plugins
    "plugins": [{ "name": "next" }],

    // Path Mapping
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  // Files to Include
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.cjs",
    "**/*.js",
    "**/*.mjs",
    ".next/types/**/*.ts"
  ],
  // Files to Exclude
  "exclude": ["node_modules"]
}
